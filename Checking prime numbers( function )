#include <iostream>
using namespace std;
void prime(int a)
{
	int count=0;
	for(int i=a; i>=1; --i)
	{
		if(a%i==0){
		count++;
	}}
	if(count==2){
		cout<<"This number is Prime number";
	}
	else
	{
		cout<<"This number is not a prime number";
	}
}
int main(){
	int a;
	cout<<"Enter a number= ";
	cin>>a;
	prime(a);
}
