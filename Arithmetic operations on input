#include <iostream>
using namespace std;
int main()
{
	float a;
	cout<<"a= ";
	cin>>a;
	
	float b;
	cout<<"b= ";
	cin>>b;
	
	char arithmetic_sign;
	cout<<"Enter arithmetic function to be performed= ";
	cin>>arithmetic_sign;
	
	switch(arithmetic_sign)
	{
		case '+':
		{ cout<<"a+b= "<<a+b;
		}
		break;
		
		case '-':
		{ cout<<"a-b= "<<a-b;
		}
		break;
		
		case '*':
		{ cout<<"a*b= "<<a*b;
		}
		break;
		
		case 'x':
		{ cout<<"axb= "<<a*b;
		}
		break;
		
		case '/':
		{ cout<<"a/b= "<<a/b;
		}
		break;
		
		default:
		cout<<"This operator is not included"; 
	}
}
